# Normaliseeri line endings repo-siseselt LF-iks, working copy-s autocrlf (Windows)
* text=auto eol=lf

# Allpool sh/shebang failid: alati LF (muidu ei k\u00e4ivitu Linuxis/Docker-is)
*.sh   text eol=lf
*.bash text eol=lf
Dockerfile text eol=lf
*.Dockerfile text eol=lf
deploy.sh text eol=lf

# Windows-spetsiifilised: alati CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Gradle wrapper
gradlew text eol=lf
gradlew.bat text eol=crlf

# Allika kood: expliitselt LF (normaliseerib ka olemasoleva repo)
