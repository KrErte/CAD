# EditorConfig — mis IDE iganes, sama formaati. https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Web-tavapraktika — 2 space
[*.{ts,tsx,js,jsx,json,html,scss,css,yaml,yml}]
indent_size = 2

# Makefile vajab tab'i
[Makefile]
indent_style = tab

# Windows batch fail'id CRLF-iga
[*.bat]
end_of_line = crlf

# Markdown ei trim trailing whitespace — see on
# line-break signifier CommonMark'is
[*.md]
trim_trailing_whitespace = false
