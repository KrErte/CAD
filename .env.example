ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-6
WORKER_URL=http://worker:8000
# Optional: enables free-form mesh fallback when no template fits
MESHY_API_KEY=

# Partnerite hinnavõrdlus (3D-print tellimine) — kõik optional.
# Tühjadena kasutame heuristilist hinnangut (volume × material rate).
PRICING_KODA_KEY=
PRICING_PRINTIDUD_KEY=
PRICING_SHAPEWAYS_KEY=
PRICING_TREATSTOCK_KEY=

# ── Database ─────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://db:5432/aicad
DB_USER=aicad
DB_PASSWORD=aicad

# ── Auth (Google OAuth2) ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=change-me-please-change-me-please-32bytes!!

# ── Stripe ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_HOBI=
STRIPE_PRICE_PRO=
STRIPE_PRICE_MAKER_MONTHLY=
STRIPE_PRICE_MAKER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_YEARLY=

# ── Object Storage (MinIO / S3) ─────────────────────────────────────
STORAGE_ENDPOINT=http://minio:9000
STORAGE_BUCKET=cad-artifacts
STORAGE_REGION=eu-north-1
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_PATH_STYLE=true

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Observability (OpenTelemetry) ────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
