{
  "name": "AI-CAD dev",
  "image": "mcr.microsoft.com/devcontainers/java:21-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1":     { "version": "20" },
    "ghcr.io/devcontainers/features/python:1":   { "version": "3.11" },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers-contrib/features/gradle-sdkman:2": { "version": "8.10" },
    "ghcr.io/devcontainers-contrib/features/pre-commit:2": {}
  },
  "postCreateCommand": "pre-commit install && cd frontend && npm install --legacy-peer-deps",
  "forwardPorts": [8080, 4200, 8000, 8100, 5432, 6379, 9000, 9001, 3000],
  "portsAttributes": {
    "8080": { "label": "Backend (Spring)" },
    "4200": { "label": "Frontend (Angular)" },
    "8000": { "label": "Worker (FastAPI)" },
    "8100": { "label": "Slicer (FastAPI)" },
    "9001": { "label": "MinIO Console" },
    "3000": { "label": "Grafana" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vscjava.vscode-gradle",
        "angular.ng-template",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-python.python",
        "ms-python.black-formatter",
        "charliermarsh.ruff",
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml",
        "ms-azuretools.vscode-docker",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "zxh404.vscode-proto3",
        "github.vscode-github-actions"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[java]": { "editor.defaultFormatter": "redhat.java" },
        "[python]": { "editor.defaultFormatter": "charliermarsh.ruff" },
        "java.format.settings.url": "https://raw.githubusercontent.com/google/styleguide/gh-pages/eclipse-java-google-style.xml",
        "java.configuration.updateBuildConfiguration": "automatic"
      }
    }
  }
}
